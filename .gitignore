# =============================================================================
#  Universal Downloader — .gitignore
#  https://github.com/BittarMO/Universal-Downloader
# =============================================================================


# -----------------------------------------------------------------------------
#  Build output
# -----------------------------------------------------------------------------
build/
dist/
*.spec.backup


# -----------------------------------------------------------------------------
#  Auto-downloaded runtime tools (fetched on first launch — not versioned)
# -----------------------------------------------------------------------------
tools_data/ffmpeg
tools_data/ffmpeg.exe
tools_data/yt-dlp
tools_data/yt-dlp.exe


# -----------------------------------------------------------------------------
#  Partial / temporary download artefacts
# -----------------------------------------------------------------------------
*.part
*.temp
*.tmp
_update.part
*.old
*.backup


# -----------------------------------------------------------------------------
#  Distributable binaries (built locally, released via GitHub Releases)
# -----------------------------------------------------------------------------
*.exe
*.app
*.msi
*.dmg
*.manifest


# -----------------------------------------------------------------------------
#  Python cache & virtual environments
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
ENV/
env/
pip-log.txt
pip-delete-this-directory.txt


# -----------------------------------------------------------------------------
#  Logs & sensitive data  (never commit secrets or local config)
# -----------------------------------------------------------------------------
*.log
*.key
*.pem
*.crt
.secrets/
config.local.*
.env
.env.*


# -----------------------------------------------------------------------------
#  macOS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes


# -----------------------------------------------------------------------------
#  Windows
# -----------------------------------------------------------------------------
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/


# -----------------------------------------------------------------------------
#  Editors & IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
