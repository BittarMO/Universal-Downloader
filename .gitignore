# ============================================
# .gitignore for Universal Downloader
# ============================================

# -------------------------------
# 1. Exclude large binary files (downloaded by the app or generated by build)
# -------------------------------
*.exe
*.app
*.msi
*.dmg

# Downloaded tools (will be fetched automatically on first run)
tools_data/ffmpeg.exe
tools_data/yt-dlp.exe
tools_data/ffmpeg
tools_data/yt-dlp

# Temporary download parts
tools_data/*.part
tools_data/*.temp
*.part

# -------------------------------
# 2. Python cache and virtual environments
# -------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
ENV/
env/
pip-log.txt
pip-delete-this-directory.txt

# -------------------------------
# 3. System files and hidden folders
# -------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -------------------------------
# 4. Build output and temporary update files
# -------------------------------
_update.part
*.old
*.backup
*.tmp
*.temp
build/
dist/
*.spec.backup
*.manifest

# -------------------------------
# 5. IDE and editor files
# -------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# -------------------------------
# 6. Logs and sensitive data
# -------------------------------
*.log
*.key
*.pem
*.crt
.secrets/
config.local.*